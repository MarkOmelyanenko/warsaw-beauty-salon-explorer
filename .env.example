# Copy to .env in the project root (gitignored). Used by Docker Compose,
# Spring Boot (backend/), Vite (frontend/), and data/collect_salons_v2.py.

# PostgreSQL (docker compose postgres service)
POSTGRES_DB=salons_db
POSTGRES_USER=salons_user
POSTGRES_PASSWORD=salons_password

# Spring Boot — use localhost when running ./mvnw spring-boot:run locally;
# Docker Compose overrides the host to "postgres" for the backend container.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/salons_db
SPRING_DATASOURCE_USERNAME=salons_user
SPRING_DATASOURCE_PASSWORD=salons_password
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Vite (npm run dev / docker frontend build arg)
VITE_API_BASE_URL=http://localhost:8080/api

# Optional: Google Places phone enrichment in data/collect_salons_v2.py
GOOGLE_PLACES_API_KEY=
